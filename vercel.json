{
  "version": 2,
  "buildCommand": "cd GmailReaderUI && npm install && npm run build",
  "outputDirectory": "GmailReaderUI/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py",
      "methods": ["GET", "POST", "DELETE", "PUT", "PATCH", "OPTIONS"]
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "headers": {
        "cache-control": "public, immutable, max-age=31536000"
      }
    },
    {
      "src": "^/(?!api).*",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
