{
  "version": 2,
  "buildCommand": "cd GmailReaderUI && npm install && npm run build",
  "outputDirectory": "GmailReaderUI/dist",
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api.py",
      "methods": ["GET", "POST", "DELETE", "PUT", "PATCH"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
